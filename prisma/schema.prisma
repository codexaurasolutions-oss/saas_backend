generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  SUPER_ADMIN
  SALON_USER
  CUSTOMER
}

enum SalonRoleCode {
  SALON_OWNER
  MANAGER
  RECEPTIONIST
  STAFF
  INVENTORY_MANAGER
  ACCOUNTANT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PaymentMode {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  WALLET
  ONLINE
}

enum InvoiceStatus {
  DRAFT
  PAID
  PARTIAL
  UNPAID
  REFUNDED
  CANCELLED
}

enum DemoLeadStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ProductType {
  RETAIL
  CONSUMABLE
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  POS_SALE
  PRODUCT_RETURN
  TRANSFER_IN
  TRANSFER_OUT
  CONSUMABLE_USAGE
  PURCHASE_RECEIVED
  RECONCILIATION
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum MembershipBenefitType {
  DISCOUNT_PERCENT
  DISCOUNT_AMOUNT
  WALLET_VALUE
}

enum CustomerPackageStatus {
  ACTIVE
  EXPIRED
  FULLY_USED
  CANCELLED
}

enum OnlineOrderStatus {
  NEW
  ACCEPTED
  READY
  COMPLETED
  CANCELLED
}

enum OrderPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CatalogAnalyticsEventType {
  QR_SCAN
  PAGE_VIEW
  SERVICE_VIEW
  PRODUCT_CLICK
  BOOKING_CLICK
  WHATSAPP_CLICK
  OFFER_CLICK
  SHOP_CLICK
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum CampaignType {
  WHATSAPP
  SMS
  EMAIL
  SOCIAL_BANNER
  CATALOG_BANNER
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  ADJUST
  BONUS
  EXPIRE
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

enum FeedbackStatus {
  NEW
  REVIEWED
  CONTACTED
  RESOLVED
}

enum EnquiryStatus {
  NEW
  CONTACTED
  INTERESTED
  CONVERTED
  LOST
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
}

enum CampaignTemplateTier {
  FREE
  PREMIUM
}

enum WhatsAppLogStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  OPEN_PLACEHOLDER
}

model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  passwordHash           String
  name                   String
  systemRole             SystemRole
  isActive               Boolean             @default(true)
  passwordSetupRequired  Boolean             @default(false)
  isDemoAccount          Boolean             @default(false)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  memberships            UserSalon[]
  passwordSetupTokens    PasswordSetupToken[]
  appointmentLogs        AppointmentLog[]
  stockMovements         StockMovement[]
  purchaseOrdersCreated  PurchaseOrder[]     @relation("PurchaseOrderCreatedBy")
  purchaseTransfersCreated StockTransfer[]   @relation("StockTransferCreatedBy")
  customerProfile        Customer?
}

model Salon {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  businessType        String?
  logoUrl             String?
  email               String?
  phone               String?
  address             String?
  city                String?
  country             String?
  timezone            String?
  currency            String?              @default("PKR")
  taxRate             Decimal?             @db.Decimal(5, 2)
  trialStartsAt       DateTime?
  trialEndsAt         DateTime?
  internalNote        String?
  status              SubscriptionStatus   @default(TRIAL)
  featureFlags        Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               UserSalon[]
  branches            Branch[]
  services            Service[]
  customers           Customer[]
  serviceCategories   ServiceCategory[]
  invoices            Invoice[]
  payments            Payment[]
  demoLeads           DemoLead[]
  subscriptions       Subscription[]
  supportTickets      SupportTicket[]
  settings            SalonSetting[]
  customRoles         CustomRole[]
  appointments        Appointment[]
  appointmentSettings AppointmentSetting[]
  products            Product[]
  productCategories   ProductCategory[]
  stockMovements      StockMovement[]
  vendors             Vendor[]
  purchaseOrders      PurchaseOrder[]
  stockTransfers      StockTransfer[]
  reconciliations     StockReconciliation[]
  membershipPlans     MembershipPlan[]
  customerMemberships CustomerMembership[]
  packages            Package[]
  customerPackages    CustomerPackage[]
  catalogSettings     CatalogSetting[]
  catalogBanners      CatalogBanner[]
  catalogOffers       CatalogOffer[]
  catalogAnalytics    CatalogAnalyticsEvent[]
  ecommerceSettings   EcommerceSetting[]
  onlineOrders        OnlineOrder[]
  campaigns           Campaign[]
  messageTemplates    MessageTemplate[]
  customerCoupons     CustomerCoupon[]
  customerNotifications CustomerNotification[]
  customerFeedback    CustomerFeedback[]
  loyaltyRules        LoyaltyRule[]
  loyaltyTransactions LoyaltyTransaction[]
  coupons             Coupon[]
  couponRedemptions   CouponRedemption[]
  giftCards           GiftCard[]
  giftCardRedemptions GiftCardRedemption[]
  enquiries           Enquiry[]
  expenseCategories   ExpenseCategory[]
  expenses            Expense[]
  attendanceRecords   AttendanceRecord[]
  leaveRequests       LeaveRequest[]
  incentiveRules      IncentiveRule[]
  payrollRuns         PayrollRun[]
  payrollItems        PayrollItem[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  campaignTemplates   CampaignTemplate[]
  campaignConversions CampaignConversion[]
  whatsappSettings    WhatsAppSetting[]
  whatsappAutomations WhatsAppAutomation[]
  whatsappLogs        WhatsAppLog[]
}

model UserSalon {
  id                   String                    @id @default(cuid())
  userId               String
  salonId              String
  salonRole            SalonRoleCode
  branchId             String?
  customRoleId         String?
  phone                String?
  profileNote          String?
  avatarUrl            String?
  roleTitle            String?
  showInCatalog        Boolean                   @default(false)
  isArchived           Boolean                   @default(false)
  permissions          Json?
  joiningDate          DateTime?
  designation          String?
  uanNumber            String?
  reportingToId        String?
  workingHours         String?
  bankName             String?
  bankBranch           String?
  accountNumber        String?
  ifscCode             String?
  user                 User                      @relation(fields: [userId], references: [id])
  salon                Salon                     @relation(fields: [salonId], references: [id])
  branch               Branch?                   @relation(fields: [branchId], references: [id])
  customRole           CustomRole?               @relation(fields: [customRoleId], references: [id])
  serviceAssignments   StaffServiceAssignment[]
  appointmentAssignments AppointmentServiceStaff[]
  appointmentPrimary   Appointment[]             @relation("AppointmentPrimaryStaff")
  invoiceItems         InvoiceItem[]
  staffSchedules       StaffSchedule[]
  staffBreaks          StaffBreak[]
  appointmentsOwned    Appointment[]             @relation("AppointmentCreatedBy")
  preferredByCustomers Customer[]               @relation("CustomerPreferredStaff")
  loyaltyTransactions  LoyaltyTransaction[]
  giftCardsCreated     GiftCard[]                @relation("GiftCardCreatedBy")
  enquiriesAssigned    Enquiry[]                 @relation("EnquiryAssignedTo")
  enquiriesCreated     Enquiry[]                 @relation("EnquiryCreatedBy")
  enquiryFollowUps     EnquiryFollowUp[]
  expensesCreated      Expense[]                 @relation("ExpenseCreatedBy")
  expensesApproved     Expense[]                 @relation("ExpenseApprovedBy")
  attendanceRecords    AttendanceRecord[]        @relation("AttendanceStaff")
  attendanceRecordedBy AttendanceRecord[]        @relation("AttendanceRecordedBy")
  leaveRequests        LeaveRequest[]            @relation("LeaveRequestedBy")
  leaveApproved        LeaveRequest[]            @relation("LeaveApprovedBy")
  incentiveRules       IncentiveRule[]
  payrollRunsGenerated PayrollRun[]              @relation("PayrollGeneratedBy")
  payrollRunsApproved  PayrollRun[]              @relation("PayrollApprovedBy")
  payrollItems         PayrollItem[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  campaignTemplates    CampaignTemplate[]        @relation("CampaignTemplateCreatedBy")
  campaignConversions  CampaignConversion[]      @relation("CampaignConversionActor")
  whatsappAutomations  WhatsAppAutomation[]      @relation("WhatsAppAutomationUpdatedBy")
  whatsappLogs         WhatsAppLog[]             @relation("WhatsAppLogActor")
  feedback             CustomerFeedback[]

  @@unique([userId, salonId])
}

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  monthlyPrice  Decimal  @db.Decimal(10, 2)
  yearlyPrice   Decimal  @db.Decimal(10, 2)
  trialDays     Int      @default(14)
  branchLimit   Int      @default(1)
  userLimit     Int      @default(5)
  customerLimit Int      @default(500)
  invoiceLimit  Int      @default(1000)
  storageLimit  Int?
  isCustom      Boolean  @default(false)
  featureFlags  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id             String                @id @default(cuid())
  salonId        String
  planId         String
  status         SubscriptionStatus    @default(TRIAL)
  paymentStatus  String?               @default("PENDING")
  manualDiscount Decimal?              @db.Decimal(10, 2)
  notes          String?
  startsAt       DateTime
  endsAt         DateTime
  reminderSentAt DateTime?
  convertedAt    DateTime?
  salon          Salon                 @relation(fields: [salonId], references: [id])
  plan           Plan                  @relation(fields: [planId], references: [id])
  history        SubscriptionHistory[]
}

model DemoLead {
  id                  String               @id @default(cuid())
  name                String
  email               String
  phone               String
  company             String?
  message             String?
  status              DemoLeadStatus       @default(PENDING)
  salonId             String?
  approvedUserId      String?
  reviewedAt          DateTime?
  reviewedByName      String?
  reviewNote          String?
  inviteSentAt        DateTime?
  createdAt           DateTime             @default(now())
  salon               Salon?               @relation(fields: [salonId], references: [id])
  passwordSetupTokens PasswordSetupToken[]
}

model PasswordSetupToken {
  id         String    @id @default(cuid())
  userId     String
  demoLeadId String?
  tokenHash  String    @unique
  purpose    String    @default("PASSWORD_SETUP")
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  demoLead   DemoLead? @relation(fields: [demoLeadId], references: [id])
}

model Branch {
  id               String                @id @default(cuid())
  salonId          String
  name             String
  phone            String?
  email            String?
  address          String?
  businessHours    String?
  weeklyOff        String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  salon            Salon                 @relation(fields: [salonId], references: [id])
  users            UserSalon[]
  services         Service[]
  invoices         Invoice[]
  settings         SalonSetting[]
  appointments     Appointment[]
  products         Product[]
  vendors          Vendor[]
  purchaseOrders   PurchaseOrder[]
  transfersFrom    StockTransfer[]       @relation("TransferSourceBranch")
  transfersTo      StockTransfer[]       @relation("TransferDestinationBranch")
  reconciliations  StockReconciliation[]
  catalogSettings  CatalogSetting[]
  onlineOrders     OnlineOrder[]
  feedback         CustomerFeedback[]
  enquiries        Enquiry[]
  expenses         Expense[]
  attendanceRecords AttendanceRecord[]
  payrollRuns      PayrollRun[]
  loyaltyRules     LoyaltyRule[]
  coupons          Coupon[]
}

model ServiceCategory {
  id        String           @id @default(cuid())
  salonId   String
  name      String
  parentId  String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  salon     Salon            @relation(fields: [salonId], references: [id])
  parent    ServiceCategory? @relation("CategoryTree", fields: [parentId], references: [id])
  children  ServiceCategory[] @relation("CategoryTree")
  services  Service[]
}

model Service {
  id                   String                    @id @default(cuid())
  salonId              String
  branchId             String?
  categoryId           String?
  name                 String
  gender               String?                   @default("UNISEX")
  price                Decimal                   @db.Decimal(10, 2)
  durationMin          Int
  description          String?
  taxRate              Decimal?                  @db.Decimal(5, 2)
  onlineBookingEnabled Boolean                   @default(false)
  commissionPct        Decimal?                  @db.Decimal(5, 2)
  isFeatured           Boolean                   @default(false)
  isPopular            Boolean                   @default(false)
  isPublicVisible      Boolean                   @default(true)
  isActive             Boolean                   @default(true)
  createdAt            DateTime                  @default(now())
  salon                Salon                     @relation(fields: [salonId], references: [id])
  branch               Branch?                   @relation(fields: [branchId], references: [id])
  category             ServiceCategory?          @relation(fields: [categoryId], references: [id])
  staffAssignments     StaffServiceAssignment[]
  appointmentItems     AppointmentService[]
  membershipPlans      MembershipPlanService[]
  packageServices      PackageService[]
  feedback             CustomerFeedback[]
  coupons              Coupon[]
  enquiries            Enquiry[]
}

model Customer {
  id               String               @id @default(cuid())
  salonId          String
  userId           String?              @unique
  name             String
  phone            String
  email            String?
  gender           String?
  dateOfBirth      DateTime?
  anniversary      DateTime?
  source           String?
  tags             Json?
  notes            String?
  preferences      String?
  preferredStaffId String?
  allergies        String?
  skinNotes        String?
  lastVisitAt      DateTime?
  totalSpend       Decimal              @default(0) @db.Decimal(12, 2)
  averageSpend     Decimal              @default(0) @db.Decimal(12, 2)
  loyaltyPoints    Int                  @default(0)
  createdAt        DateTime             @default(now())
  salon            Salon                @relation(fields: [salonId], references: [id])
  user             User?                @relation(fields: [userId], references: [id])
  invoices         Invoice[]
  appointments     Appointment[]
  memberships      CustomerMembership[]
  packages         CustomerPackage[]
  preferredStaff   UserSalon?           @relation("CustomerPreferredStaff", fields: [preferredStaffId], references: [id])
  timelineEntries  CustomerTimeline[]
  orders           OnlineOrder[]
  coupons          CustomerCoupon[]
  notifications    CustomerNotification[]
  feedback         CustomerFeedback[]
  loyaltyTransactions LoyaltyTransaction[]
  couponRedemptions   CouponRedemption[]
  giftCardsIssued     GiftCard[]            @relation("GiftCardIssuedTo")
  giftCardRedemptions GiftCardRedemption[]
  enquiries           Enquiry[]             @relation("EnquiryConvertedCustomer")
  campaignConversions CampaignConversion[]
  whatsappLogs        WhatsAppLog[]

  @@unique([salonId, phone])
}

model Invoice {
  id                   String                @id @default(cuid())
  salonId              String
  branchId             String?
  customerId           String
  appointmentId        String?
  invoiceNumber        String                @unique
  status               InvoiceStatus         @default(UNPAID)
  subtotal             Decimal               @db.Decimal(10, 2)
  discount             Decimal               @db.Decimal(10, 2)
  tax                  Decimal               @db.Decimal(10, 2)
  total                Decimal               @db.Decimal(10, 2)
  paidAmount           Decimal               @default(0) @db.Decimal(10, 2)
  refundAmount         Decimal               @default(0) @db.Decimal(10, 2)
  balanceAmount        Decimal               @default(0) @db.Decimal(10, 2)
  notes                String?
  couponCode           String?
  giftVoucherCode      String?
  loyaltyPointsUsed    Int?
  paymentLinkToken     String?               @unique
  paymentLinkStatus    String?
  paymentLinkExpiresAt DateTime?
  createdAt            DateTime              @default(now())
  salon                Salon                 @relation(fields: [salonId], references: [id])
  branch               Branch?               @relation(fields: [branchId], references: [id])
  customer             Customer              @relation(fields: [customerId], references: [id])
  appointment          Appointment?          @relation(fields: [appointmentId], references: [id])
  items                InvoiceItem[]
  payments             Payment[]
  membershipSales      CustomerMembership[]  @relation("MembershipSaleInvoice")
  packageSales         CustomerPackage[]     @relation("PackageSaleInvoice")
  onlineOrders         OnlineOrder[]
  loyaltyTransactions  LoyaltyTransaction[]
  couponRedemptions    CouponRedemption[]
  giftCardRedemptions  GiftCardRedemption[]
  feedback             CustomerFeedback[]
  giftCardsSold        GiftCard[]
  campaignConversions  CampaignConversion[]
}

model InvoiceItem {
  id                  String           @id @default(cuid())
  invoiceId           String
  serviceId           String?
  productId           String?
  membershipPlanId    String?
  packageId           String?
  staffUserSalonId    String?
  serviceName         String
  staffName           String?
  qty                 Int
  unitPrice           Decimal          @db.Decimal(10, 2)
  taxPct              Decimal          @db.Decimal(5, 2)
  lineTotal           Decimal          @db.Decimal(10, 2)
  itemType            String           @default("SERVICE")
  appliedBenefitType  String?
  appliedBenefitValue Decimal?         @db.Decimal(10, 2)
  packageSessionsUsed Int?             @default(0)
  membershipWalletUsed Decimal?        @db.Decimal(10, 2)
  commissionAmount    Decimal?         @db.Decimal(10, 2)
  invoice             Invoice          @relation(fields: [invoiceId], references: [id])
  product             Product?         @relation(fields: [productId], references: [id])
  membershipPlan      MembershipPlan?  @relation(fields: [membershipPlanId], references: [id])
  package             Package?         @relation(fields: [packageId], references: [id])
  staffUserSalon      UserSalon?       @relation(fields: [staffUserSalonId], references: [id])
}

model Payment {
  id           String      @id @default(cuid())
  salonId      String
  invoiceId    String
  amount       Decimal     @db.Decimal(10, 2)
  mode         PaymentMode
  note         String?
  type         String      @default("PAYMENT")
  onlineStatus String?
  gatewayName  String?
  gatewayRef   String?
  createdAt    DateTime    @default(now())
  salon        Salon       @relation(fields: [salonId], references: [id])
  invoice      Invoice     @relation(fields: [invoiceId], references: [id])
}

model StaffServiceAssignment {
  id          String    @id @default(cuid())
  userSalonId String
  serviceId   String
  createdAt   DateTime  @default(now())
  userSalon   UserSalon @relation(fields: [userSalonId], references: [id])
  service     Service   @relation(fields: [serviceId], references: [id])

  @@unique([userSalonId, serviceId])
}

model Appointment {
  id                     String                     @id @default(cuid())
  salonId                String
  branchId               String
  customerId             String
  primaryStaffUserId     String?
  createdByMembershipId  String?
  title                  String?
  bookingChannel         String                     @default("MANUAL")
  status                 AppointmentStatus          @default(PENDING)
  startAt                DateTime
  endAt                  DateTime
  notes                  String?
  customerPreferences    String?
  isWalkIn               Boolean                    @default(false)
  approvalStatus         String?                    @default("APPROVED")
  advancePaymentRequired Boolean                    @default(false)
  advancePaidAmount      Decimal?                   @db.Decimal(10, 2)
  selfCancelToken        String?                    @unique
  selfRescheduleToken    String?                    @unique
  roomResourceNote       String?
  convertedInvoiceId     String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  salon                  Salon                      @relation(fields: [salonId], references: [id])
  branch                 Branch                     @relation(fields: [branchId], references: [id])
  customer               Customer                   @relation(fields: [customerId], references: [id])
  primaryStaff           UserSalon?                 @relation("AppointmentPrimaryStaff", fields: [primaryStaffUserId], references: [id])
  createdByMembership    UserSalon?                 @relation("AppointmentCreatedBy", fields: [createdByMembershipId], references: [id])
  invoice                Invoice[]
  items                  AppointmentService[]
  logs                   AppointmentLog[]
  feedback               CustomerFeedback[]
  convertedFromEnquiries Enquiry[]

  @@index([salonId, branchId, startAt])
  @@index([salonId, customerId, startAt])
}

model AppointmentService {
  id            String                    @id @default(cuid())
  appointmentId String
  serviceId     String
  startAt       DateTime
  endAt         DateTime
  notes         String?
  appointment   Appointment               @relation(fields: [appointmentId], references: [id])
  service       Service                   @relation(fields: [serviceId], references: [id])
  assignedStaff AppointmentServiceStaff[]
}

model AppointmentServiceStaff {
  id                   String              @id @default(cuid())
  appointmentServiceId String
  userSalonId          String
  appointmentService   AppointmentService  @relation(fields: [appointmentServiceId], references: [id])
  userSalon            UserSalon           @relation(fields: [userSalonId], references: [id])

  @@unique([appointmentServiceId, userSalonId])
}

model AppointmentLog {
  id            String             @id @default(cuid())
  appointmentId String
  actorUserId   String?
  action        String
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus?
  details       String?
  createdAt     DateTime           @default(now())
  appointment   Appointment        @relation(fields: [appointmentId], references: [id])
  actorUser     User?              @relation(fields: [actorUserId], references: [id])
}

model AppointmentSetting {
  id                     String   @id @default(cuid())
  salonId                String
  branchId               String?
  autoConfirm            Boolean  @default(true)
  advancePaymentRequired Boolean  @default(false)
  onlineBookingEnabled   Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  salon                  Salon    @relation(fields: [salonId], references: [id])

  @@unique([salonId, branchId])
}

model StaffSchedule {
  id          String    @id @default(cuid())
  salonId     String
  branchId    String?
  userSalonId String
  weekday     Int
  startTime   String
  endTime     String
  isOffDay    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userSalon   UserSalon @relation(fields: [userSalonId], references: [id])

  @@unique([userSalonId, weekday])
}

model StaffBreak {
  id          String    @id @default(cuid())
  userSalonId String
  weekday     Int
  startTime   String
  endTime     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userSalon   UserSalon @relation(fields: [userSalonId], references: [id])
}

model ProductCategory {
  id              String    @id @default(cuid())
  salonId         String
  name            String
  description     String?
  imageUrl        String?
  sortOrder       Int       @default(0)
  isPublicVisible Boolean   @default(true)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  salon           Salon     @relation(fields: [salonId], references: [id])
  products        Product[]
}

model Product {
  id                 String               @id @default(cuid())
  salonId            String
  branchId           String?
  categoryId         String?
  name               String
  imageUrl           String?
  sku                String?
  barcode            String?
  productType        ProductType          @default(RETAIL)
  costPrice          Decimal              @db.Decimal(10, 2)
  sellingPrice       Decimal              @db.Decimal(10, 2)
  currentStock       Decimal              @default(0) @db.Decimal(12, 2)
  minStock           Decimal              @default(0) @db.Decimal(12, 2)
  expiryDate         DateTime?
  allowNegativeStock Boolean              @default(false)
  isOnlineVisible    Boolean              @default(true)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  salon              Salon                @relation(fields: [salonId], references: [id])
  branch             Branch?              @relation(fields: [branchId], references: [id])
  category           ProductCategory?     @relation(fields: [categoryId], references: [id])
  stockMovements     StockMovement[]
  invoiceItems       InvoiceItem[]
  purchaseItems      PurchaseOrderItem[]
  transferItems      StockTransferItem[]
  reconciliationItems StockReconciliationItem[]
  orderItems         OnlineOrderItem[]
  coupons            Coupon[]

  @@unique([salonId, sku])
}

model StockMovement {
  id              String            @id @default(cuid())
  salonId         String
  branchId        String?
  productId       String
  createdByUserId String?
  movementType    StockMovementType
  quantity        Decimal           @db.Decimal(12, 2)
  stockBefore     Decimal           @db.Decimal(12, 2)
  stockAfter      Decimal           @db.Decimal(12, 2)
  referenceType   String?
