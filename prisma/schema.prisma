  @@unique([salonId, code])
}

model GiftCardRedemption {
  id           String      @id @default(cuid())
  salonId      String
  giftCardId   String
  customerId   String?
  invoiceId    String?
  orderId      String?
  amountUsed   Decimal     @db.Decimal(10, 2)
  createdAt    DateTime    @default(now())
  salon        Salon       @relation(fields: [salonId], references: [id])
  giftCard     GiftCard    @relation(fields: [giftCardId], references: [id])
  customer     Customer?   @relation(fields: [customerId], references: [id])
  invoice      Invoice?    @relation(fields: [invoiceId], references: [id])
  order        OnlineOrder? @relation(fields: [orderId], references: [id])
}

model Enquiry {
  id                   String         @id @default(cuid())
  salonId              String
  interestedServiceId  String?
  interestedBranchId   String?
  assignedToMembershipId String?
  createdByMembershipId String?
  convertedCustomerId  String?
  convertedAppointmentId String?
  name                 String
  phone                String
  email                String?
  source               String
  budget               Decimal?       @db.Decimal(10, 2)
  priority             String?        @default("MEDIUM")
  status               EnquiryStatus  @default(NEW)
  followUpAt           DateTime?
  notes                String?
  archivedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  salon                Salon          @relation(fields: [salonId], references: [id])
  interestedService    Service?       @relation(fields: [interestedServiceId], references: [id])
  interestedBranch     Branch?        @relation(fields: [interestedBranchId], references: [id])
  assignedToMembership UserSalon?     @relation("EnquiryAssignedTo", fields: [assignedToMembershipId], references: [id])
  createdByMembership  UserSalon?     @relation("EnquiryCreatedBy", fields: [createdByMembershipId], references: [id])
  convertedCustomer    Customer?      @relation("EnquiryConvertedCustomer", fields: [convertedCustomerId], references: [id])
  convertedAppointment Appointment?   @relation(fields: [convertedAppointmentId], references: [id])
  followUps            EnquiryFollowUp[]
}

model EnquiryFollowUp {
  id               String    @id @default(cuid())
  enquiryId        String
  actorMembershipId String?
  note             String
  status           String?
  dueAt            DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  enquiry          Enquiry   @relation(fields: [enquiryId], references: [id])
  actorMembership  UserSalon? @relation(fields: [actorMembershipId], references: [id])
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  salonId     String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  salon       Salon    @relation(fields: [salonId], references: [id])
  expenses    Expense[]

  @@unique([salonId, name])
}

model Expense {
  id                   String        @id @default(cuid())
  salonId              String
  branchId             String?
  categoryId           String?
  vendorId             String?
  createdByMembershipId String?
  approvedByMembershipId String?
  title                String
  amount               Decimal       @db.Decimal(10, 2)
  expenseDate          DateTime      @default(now())
  paymentMode          PaymentMode?
  status               ExpenseStatus @default(PENDING)
  notes                String?
  receiptUrl           String?
  attachmentUrl        String?
  approvalNote         String?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  salon                Salon         @relation(fields: [salonId], references: [id])
  branch               Branch?       @relation(fields: [branchId], references: [id])
  category             ExpenseCategory? @relation(fields: [categoryId], references: [id])
  vendor               Vendor?       @relation(fields: [vendorId], references: [id])
  createdByMembership  UserSalon?    @relation("ExpenseCreatedBy", fields: [createdByMembershipId], references: [id])
  approvedByMembership UserSalon?    @relation("ExpenseApprovedBy", fields: [approvedByMembershipId], references: [id])
}

model AttendanceRecord {
  id                   String    @id @default(cuid())
  salonId              String
  branchId             String?
  userSalonId          String
  createdByMembershipId String?
  checkInAt            DateTime
  checkOutAt           DateTime?
  workedMinutes        Int?
  note                 String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  salon                Salon     @relation(fields: [salonId], references: [id])
  branch               Branch?   @relation(fields: [branchId], references: [id])
  userSalon            UserSalon @relation("AttendanceStaff", fields: [userSalonId], references: [id])
  createdByMembership  UserSalon? @relation("AttendanceRecordedBy", fields: [createdByMembershipId], references: [id])
}

model LeaveRequest {
  id                   String      @id @default(cuid())
  salonId              String
  userSalonId          String
  approvedByMembershipId String?
  startDate            DateTime
  endDate              DateTime
  reason               String?
  note                 String?
  status               LeaveStatus @default(PENDING)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  salon                Salon       @relation(fields: [salonId], references: [id])
  userSalon            UserSalon   @relation("LeaveRequestedBy", fields: [userSalonId], references: [id])
  approvedByMembership UserSalon?  @relation("LeaveApprovedBy", fields: [approvedByMembershipId], references: [id])
}

model IncentiveRule {
  id            String   @id @default(cuid())
  salonId       String
  createdByMembershipId String?
  name          String
  targetType    String
  minTarget     Decimal? @db.Decimal(10, 2)
  incentiveAmount Decimal @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  salon         Salon    @relation(fields: [salonId], references: [id])
  createdByMembership UserSalon? @relation(fields: [createdByMembershipId], references: [id])
}

model PayrollRun {
  id                   String        @id @default(cuid())
  salonId              String
  branchId             String?
  generatedByMembershipId String?
  approvedByMembershipId String?
  periodStart          DateTime
  periodEnd            DateTime
  status               PayrollStatus @default(DRAFT)
  notes                String?
  totalBaseSalary      Decimal       @default(0) @db.Decimal(12, 2)
  totalCommission      Decimal       @default(0) @db.Decimal(12, 2)
  totalIncentive       Decimal       @default(0) @db.Decimal(12, 2)
  totalAdjustments     Decimal       @default(0) @db.Decimal(12, 2)
  totalNet             Decimal       @default(0) @db.Decimal(12, 2)
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  salon                Salon         @relation(fields: [salonId], references: [id])
  branch               Branch?       @relation(fields: [branchId], references: [id])
  generatedByMembership UserSalon?   @relation("PayrollGeneratedBy", fields: [generatedByMembershipId], references: [id])
  approvedByMembership UserSalon?    @relation("PayrollApprovedBy", fields: [approvedByMembershipId], references: [id])
  items                PayrollItem[]
}

model PayrollItem {
  id                String     @id @default(cuid())
  salonId           String
  payrollRunId      String
  userSalonId       String
  baseSalary        Decimal    @default(0) @db.Decimal(12, 2)
  commissionAmount  Decimal    @default(0) @db.Decimal(12, 2)
  incentiveAmount   Decimal    @default(0) @db.Decimal(12, 2)
  adjustmentAmount  Decimal    @default(0) @db.Decimal(12, 2)
  attendanceDeduction Decimal  @default(0) @db.Decimal(12, 2)
  leaveDeduction    Decimal    @default(0) @db.Decimal(12, 2)
  netAmount         Decimal    @default(0) @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  salon             Salon      @relation(fields: [salonId], references: [id])
  payrollRun        PayrollRun @relation(fields: [payrollRunId], references: [id])
  userSalon         UserSalon  @relation(fields: [userSalonId], references: [id])
}

model Notification {
  id           String    @id @default(cuid())
  salonId      String
  userSalonId  String?
  title        String
  message      String
  type         String?
  linkUrl      String?
  isRead       Boolean   @default(false)
  metadata     Json?
  createdAt    DateTime  @default(now())
  salon        Salon     @relation(fields: [salonId], references: [id])
  userSalon    UserSalon? @relation(fields: [userSalonId], references: [id])
}

model AuditLog {
  id                String    @id @default(cuid())
  salonId           String?
  actorUserId       String?
  actorMembershipId String?
  module            String
  action            String
  entityType        String?
  entityId          String?
  reference         String?
  summary           String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  salon             Salon?    @relation(fields: [salonId], references: [id])
  actorMembership   UserSalon? @relation(fields: [actorMembershipId], references: [id])
}

model CampaignTemplate {
  id                   String               @id @default(cuid())
  salonId              String
  createdByMembershipId String?
  name                 String
  title                String
  tier                 CampaignTemplateTier @default(FREE)
  category             String?
  backgroundColor      String?
  textColor            String?
  offerText            String?
  logoUrl              String?
  imageUrl             String?
  layoutJson           Json?
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  salon                Salon                @relation(fields: [salonId], references: [id])
  createdByMembership  UserSalon?           @relation("CampaignTemplateCreatedBy", fields: [createdByMembershipId], references: [id])
  campaigns            Campaign[]
}

model CampaignConversion {
  id                   String      @id @default(cuid())
  salonId              String
  campaignId           String
  customerId           String?
  invoiceId            String?
  orderId              String?
  actorMembershipId    String?
  revenueAmount        Decimal     @default(0) @db.Decimal(12, 2)
  createdAt            DateTime    @default(now())
  salon                Salon       @relation(fields: [salonId], references: [id])
  campaign             Campaign    @relation(fields: [campaignId], references: [id])
  customer             Customer?   @relation(fields: [customerId], references: [id])
  invoice              Invoice?    @relation(fields: [invoiceId], references: [id])
  order                OnlineOrder? @relation(fields: [orderId], references: [id])
  actorMembership      UserSalon?  @relation("CampaignConversionActor", fields: [actorMembershipId], references: [id])
}

model WhatsAppSetting {
  id                 String   @id @default(cuid())
  salonId            String
  providerName       String?
  senderName         String?
  apiUrl             String?
  apiKeyPlaceholder  String?
  automationEnabled  Boolean  @default(false)
  deliveryStatusEnabled Boolean @default(false)
  readStatusEnabled  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  salon              Salon    @relation(fields: [salonId], references: [id])

  @@unique([salonId])
}

model WhatsAppAutomation {
  id                   String   @id @default(cuid())
  salonId              String
  updatedByMembershipId String?
  eventKey             String
  templateType         String
  audienceFilter       String?
  mediaKind            String?
  mediaUrl             String?
  isEnabled            Boolean  @default(true)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  salon                Salon    @relation(fields: [salonId], references: [id])
  updatedByMembership  UserSalon? @relation("WhatsAppAutomationUpdatedBy", fields: [updatedByMembershipId], references: [id])
}

model WhatsAppLog {
  id                String            @id @default(cuid())
  salonId           String
  customerId        String?
  actorMembershipId String?
  campaignId        String?
  phone             String
  templateType      String?
  message           String
  status            WhatsAppLogStatus @default(PENDING)
  linkUrl           String?
  metadata          Json?
  createdAt         DateTime          @default(now())
  salon             Salon             @relation(fields: [salonId], references: [id])
  customer          Customer?         @relation(fields: [customerId], references: [id])
  actorMembership   UserSalon?        @relation("WhatsAppLogActor", fields: [actorMembershipId], references: [id])
  campaign          Campaign?         @relation(fields: [campaignId], references: [id])
}
